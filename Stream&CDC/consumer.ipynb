# SCHEMAS (matching Kafka JSON messages)

customer_schema = StructType([
    StructField("customer_unique_id",        StringType()),
    StructField("customer_zip_code_prefix",  IntegerType()),
    StructField("customer_city",             StringType()),
    StructField("customer_state",            StringType()),
])

item_schema = ArrayType(
    StructType([
        StructField("order_item_id",       IntegerType()),
        StructField("product_id",          StringType()),
        StructField("seller_id",           StringType()),
        StructField("shipping_limit_date", StringType()),
        StructField("price",               DoubleType()),
        StructField("freight_value",       DoubleType()),
    ])
)

payment_schema = ArrayType(
    StructType([
        StructField("payment_sequential",   IntegerType()),
        StructField("payment_type",         StringType()),
        StructField("payment_installments", IntegerType()),
        StructField("payment_value",        DoubleType()),
    ])
)

order_schema = StructType([
    StructField("event_type",                     StringType()),
    StructField("order_id",                       StringType()),
    StructField("customer_id",                    StringType()),
    StructField("order_status",                   StringType()),
    StructField("event_timestamp",                StringType()),
    StructField("order_estimated_delivery_date",  StringType()),
    StructField("customer",                       customer_schema),
    StructField("items",                          item_schema),
    StructField("payments",                       payment_schema),
])

review_schema = StructType([
    StructField("event_type",                StringType()),
    StructField("review_id",                 StringType()),
    StructField("order_id",                  StringType()),
    StructField("review_score",              IntegerType()),
    StructField("review_comment_title",      StringType()),
    StructField("review_comment_message",    StringType()),
    StructField("review_creation_date",      StringType()),
    StructField("review_answer_timestamp",   StringType()),
])

# READ ORDERS STREAM

orders_raw = (
    spark.readStream
    .format("kafka")
    .option("kafka.bootstrap.servers", KAFKA_BOOTSTRAP)
    .option("subscribe", "olist.orders")
    .option("startingOffsets", "earliest")
    .load()
)

orders = (
    orders_raw
    .selectExpr("CAST(value AS STRING)")
    .select(from_json(col("value"), order_schema).alias("data"))
    .select("data.*")
    # ── parse original event timestamp (historical date from dataset) ──
    .withColumn("event_timestamp", to_timestamp("event_timestamp"))
    # ── ingested_at = real wall-clock time this row arrived in Spark ──
    # This is what Grafana will use for "last 10 minutes / last hour" filters
    .withColumn("ingested_at", current_timestamp())
    # ── keep nested fields as JSON strings for orders_stream table ──
    .withColumn("customer_json", to_json(col("customer")))
    .withColumn("items_json",    to_json(col("items")))
    .withColumn("payments_json", to_json(col("payments")))
    .select(
        "event_type", "order_id", "customer_id", "order_status",
        "event_timestamp", "order_estimated_delivery_date",
        "customer_json", "items_json", "payments_json",
        "ingested_at",   # ← added
        # keep parsed structs for exploding in write function
        "customer", "items", "payments",
    )
)


# READ REVIEWS STREAM

reviews_raw = (
    spark.readStream
    .format("kafka")
    .option("kafka.bootstrap.servers", KAFKA_BOOTSTRAP)
    .option("subscribe", "olist.reviews")
    .option("startingOffsets", "earliest")
    .load()
)

reviews = (
    reviews_raw
    .selectExpr("CAST(value AS STRING)")
    .select(from_json(col("value"), review_schema).alias("data"))
    .select("data.*")
    .withColumn("review_answer_timestamp", to_timestamp("review_answer_timestamp"))
    # ── ingested_at for Grafana time filtering ──
    .withColumn("ingested_at", current_timestamp())
)

