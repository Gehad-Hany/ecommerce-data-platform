# WRITE ORDERS — 4 tables from one batch

def write_orders(batch_df, batch_id):
    print(f"\n── Batch {batch_id} | Total rows: {batch_df.count()} ──")

    # cache so we don't recompute the batch multiple times
    batch_df.cache()

    # ── 1. orders_stream ──────────────────────────────────────────────
    # All status events (created / approved / shipped / delivered)
    # Grafana uses this for order status funnel and order counts
    (
        batch_df
        .select(
            "event_type", "order_id", "customer_id", "order_status",
            "event_timestamp", "order_estimated_delivery_date",
            "customer_json", "items_json", "payments_json",
            "ingested_at"
        )
        .write.mode("append")
        .jdbc(POSTGRES_URL, "orders_stream", properties=POSTGRES_PROPERTIES)
    )
    print(f" orders_stream written")

    # filter to 'created' only — items/payments/customer only exist here
    created = batch_df.filter(col("order_status") == "created").cache()
    created_count = created.count()
    print(f"  'created' events in this batch: {created_count}")

    if created_count > 0:

        # ── 2. dim_customers ──────────────────────────────────────────
        # One row per customer with proper columns (no JSON blob)
        # dropDuplicates prevents re-inserting same customer across batches
        (
            created
            .select(
                col("customer_id"),
                col("customer")["customer_unique_id"]       .alias("customer_unique_id"),
                col("customer")["customer_zip_code_prefix"] .alias("zip_code_prefix"),
                col("customer")["customer_city"]            .alias("city"),
                col("customer")["customer_state"]           .alias("state"),
                col("ingested_at")
            )
            .dropDuplicates(["customer_id"])
            .write.mode("append")
            .jdbc(POSTGRES_URL, "dim_customers", properties=POSTGRES_PROPERTIES)
        )
        print(f"  dim_customers written")

        # ── 3. fact_order_items ───────────────────────────────────────
        # One row per item per order — explode the items array
        # Grafana uses this for: most ordered product, revenue per product
        (
            created
            .select(
                col("order_id"),
                col("customer_id"),
                col("ingested_at"),
                explode(col("items")).alias("item")
            )
            .select(
                col("order_id"),
                col("customer_id"),
                col("ingested_at"),
                col("item.order_item_id")       .alias("order_item_id"),
                col("item.product_id")          .alias("product_id"),
                col("item.seller_id")           .alias("seller_id"),
                col("item.shipping_limit_date") .alias("shipping_limit_date"),
                col("item.price")               .alias("price"),
                col("item.freight_value")       .alias("freight_value"),
            )
            .write.mode("append")
            .jdbc(POSTGRES_URL, "fact_order_items", properties=POSTGRES_PROPERTIES)
        )
        print(f"  fact_order_items written")

        # ── 4. fact_payments ──────────────────────────────────────────
        # One row per payment per order — explode the payments array
        # Grafana uses this for: avg payment per order, payment type breakdown
        (
            created
            .select(
                col("order_id"),
                col("customer_id"),
                col("ingested_at"),
                explode(col("payments")).alias("payment")
            )
            .select(
                col("order_id"),
                col("customer_id"),
                col("ingested_at"),
                col("payment.payment_sequential")   .alias("payment_sequential"),
                col("payment.payment_type")         .alias("payment_type"),
                col("payment.payment_installments") .alias("payment_installments"),
                col("payment.payment_value")        .alias("payment_value"),
            )
            .write.mode("append")
            .jdbc(POSTGRES_URL, "fact_payments", properties=POSTGRES_PROPERTIES)
        )
        print(f"  fact_payments written")

    created.unpersist()
    batch_df.unpersist()


# WRITE REVIEWS — unchanged logic, added ingested_at

def write_reviews(batch_df, batch_id):
    print(f"\nWriting Reviews Batch: {batch_id} | Rows: {batch_df.count()}")
    (
        batch_df
        .select(
            "event_type", "review_id", "order_id", "review_score",
            "review_comment_title", "review_comment_message",
            "review_creation_date", "review_answer_timestamp",
            "ingested_at"  
        )
        .write.mode("append")
        .jdbc(POSTGRES_URL, "reviews_stream", properties=POSTGRES_PROPERTIES)
    )
    print(f"  reviews_stream written")

# ──────────────────────────────────────────────
# START STREAMS
# ──────────────────────────────────────────────
orders_query = (
    orders.writeStream
    .foreachBatch(write_orders)
    .outputMode("append")
    .option("checkpointLocation", "/home/checkpoints/orders")
    .start()
)

reviews_query = (
    reviews.writeStream
    .foreachBatch(write_reviews)
    .outputMode("append")
    .option("checkpointLocation", "/home/checkpoints/reviews")
    .start()
)

print("\n Streaming started......\n")
spark.streams.awaitAnyTermination()
